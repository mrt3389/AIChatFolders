{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "description": "__MSG_extDescription__",
  "version": "1.0.0",
  "default_locale": "zh_CN",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.doubao.com/*",
    "https://www.kimi.com/*",
    "https://kimi.com/*",
    "https://kimi.moonshot.cn/*",
    "https://kimi.ai/*",
    "https://chat.deepseek.com/*"
  ],
  "background": {
    "scripts": ["src/background/service-worker.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.doubao.com/chat/*",
        "https://www.kimi.com/*",
        "https://kimi.com/*",
        "https://kimi.moonshot.cn/*",
        "https://kimi.ai/*",
        "https://chat.deepseek.com/*"
      ],
      "js": [
        "src/utils/browser-compat.js",
        "src/utils/uuid.js",
        "src/utils/dom.js",
        "src/utils/debounce.js",
        "src/utils/sanitize.js",
        "src/utils/i18n.js",
        "src/core/message-bus.js",
        "src/content/platform-detector.js",
        "src/content/adapters/base-adapter.js",
        "src/content/adapters/deepseek-adapter.js",
        "src/content/adapters/kimi-adapter.js",
        "src/content/adapters/doubao-adapter.js",
        "src/content/observers/conversation-watcher.js",
        "src/ui/icons/svg-sprites.js",
        "src/ui/components/toast.js",
        "src/ui/components/modal.js",
        "src/ui/components/context-menu.js",
        "src/ui/components/conversation-item.js",
        "src/ui/components/search-bar.js",
        "src/ui/components/drag-drop-manager.js",
        "src/ui/components/folder-tree.js",
        "src/ui/themes/theme-detector.js",
        "src/ui/sidebar/sidebar-panel.js",
        "src/content/injector.js",
        "src/content/main.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/ui/themes/variables.css",
        "src/ui/themes/light.css",
        "src/ui/themes/dark.css",
        "src/ui/sidebar/sidebar.css"
      ],
      "matches": [
        "https://www.doubao.com/*",
        "https://www.kimi.com/*",
        "https://kimi.com/*",
        "https://kimi.moonshot.cn/*",
        "https://kimi.ai/*",
        "https://chat.deepseek.com/*"
      ]
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ai-chat-folders@extension",
      "strict_min_version": "109.0"
    }
  }
}
